{
  "name": "nestava-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nestava Suite — Layer 2 backend (multi-tenant API, Postgres + RLS, Clerk auth, Stripe billing).",
  "scripts": {
    "dev": "tsx watch src/api/index.ts",
    "db:push": "drizzle-kit push",
    "db:rls": "psql \"$DATABASE_URL\" -f sql/rls.sql",
    "seed": "tsx src/seed.ts",
    "setup": "npm run db:push && npm run db:rls && npm run seed"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "@hono/node-server": "^1.13.7",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.14",
    "postgres": "^3.4.5",
    "stripe": "^17.5.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
